# =============================================================================
# SubterraDB — environment variables
# =============================================================================
# Copy this file to `.env` (NOT .env.local) before the first boot:
#
#   cp .env.example .env
#
# `bin/install.sh` will offer to do it for you AND fill in the secrets with
# strong randomly-generated values, so you usually don't need to edit this
# by hand.
#
# Notes:
#   * `.env` is gitignored — never commit it.
#   * Variables ending in _INTERNAL are how the GUI container talks to
#     postgres / kong INSIDE the docker network. Don't change unless you
#     know what you're doing.
#   * Variables ending in _PUBLIC are what gets shown to developers in the
#     project's connection card so their apps can reach the gateway from
#     OUTSIDE the docker network. These are what you want to override when
#     deploying on a real server.

# -----------------------------------------------------------------------------
# Database (control plane)
# -----------------------------------------------------------------------------
# Internal — used by the GUI container to talk to postgres on the docker net.
# In dev mode (running Next.js on the host) override to localhost:55432.
SUBTERRADB_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/subterradb_system

# -----------------------------------------------------------------------------
# Kong gateway
# -----------------------------------------------------------------------------
# Internal Admin API URL — the GUI container hits this to provision routes.
KONG_ADMIN_URL=http://kong:8001

# Public proxy URL — what developers paste into their @supabase/supabase-js
# clients. In production set this to the externally-reachable hostname:
#   KONG_PROXY_URL=http://192.168.1.50:58000
# or with a real domain + reverse proxy:
#   KONG_PROXY_URL=https://api.subterra.tu-empresa.com
KONG_PROXY_URL=http://localhost:58000

# Where Kong forwards storage/realtime requests when no per-project upstream
# is configured. The default points at the bundled httpbin placeholder.
KONG_UPSTREAM_PLACEHOLDER=http://upstream-placeholder/anything

# -----------------------------------------------------------------------------
# Public Postgres host — shown in connection card / MCP card
# -----------------------------------------------------------------------------
# What developers' tools (psql, MCP, db clients) use to reach the project DBs.
# Defaults to localhost for dev. In production set the public host + port:
#   SUBTERRADB_PUBLIC_DB_HOST=192.168.1.50
#   SUBTERRADB_PUBLIC_DB_PORT=55432
SUBTERRADB_PUBLIC_DB_HOST=localhost
SUBTERRADB_PUBLIC_DB_PORT=55432

# -----------------------------------------------------------------------------
# Auth — JWT signing
# -----------------------------------------------------------------------------
# Strong random secret used to sign session JWTs for the GUI's own login.
# bin/install.sh generates one for you with `openssl rand -base64 48` if .env
# doesn't already have one. NEVER reuse this between deployments.
SUBTERRADB_JWT_SECRET=replace-me-with-openssl-rand-base64-48

# -----------------------------------------------------------------------------
# Bootstrap admin user
# -----------------------------------------------------------------------------
# Created automatically the first time anyone hits /api/auth/login if no
# admin user exists yet. After the first login you can change the password
# from the GUI Settings page.
SUBTERRADB_ADMIN_EMAIL=admin@subterra.local
SUBTERRADB_ADMIN_PASSWORD=replace-me-with-a-strong-password
SUBTERRADB_ADMIN_NAME=SubterraDB Admin

# -----------------------------------------------------------------------------
# Postgres superuser password (used by the docker-compose stack)
# -----------------------------------------------------------------------------
# This is the password for the `postgres` superuser inside the bundled
# postgres container. The control plane and per-project containers use it
# internally; it never leaves the docker network.
POSTGRES_PASSWORD=postgres
