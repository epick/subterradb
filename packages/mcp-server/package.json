{
  "name": "@subterradb/mcp-server",
  "version": "0.1.2",
  "description": "Model Context Protocol server for SubterraDB — connects Claude Code, Cursor, Windsurf and other MCP clients to a local SubterraDB project so an agent can list tables, run SQL, and inspect project metadata without leaving the editor.",
  "license": "MIT",
  "author": "Epick",
  "homepage": "https://github.com/epick/subterradb#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/epick/subterradb.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/epick/subterradb/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "subterradb",
    "supabase",
    "self-hosted",
    "postgres",
    "claude",
    "cursor",
    "windsurf",
    "ai",
    "llm-tools"
  ],
  "type": "module",
  "bin": {
    "mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.0"
  }
}
