# Keep the Docker build context small.

# Dependencies and build outputs (rebuilt inside the image)
node_modules
**/node_modules
.next
out
dist
build
**/dist
**/build

# Local env (env vars come from docker-compose at runtime)
.env
.env.local
.env.*.local

# Git internals
.git
.gitignore
.gitattributes

# Editor / IDE
.vscode
.idea

# OS junk
.DS_Store
Thumbs.db

# Docs not needed at runtime
README.md
LICENSE
docs

# bin/ scripts run on the host, not inside the image
bin
